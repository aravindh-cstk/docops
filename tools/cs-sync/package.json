{
  "name": "@contentstack/docs-sync",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync": "tsx src/index.ts",
    "lint": "tsx src/lint.ts",
    "fix": "tsx src/fix.ts",
    "fix:check": "npm run fix && npm run lint",
    "cms-pull": "tsx src/cms-pull.ts",
    "image-inject": "tsx src/image-inject.ts",
    "rebuild-stubs": "tsx src/rebuild-stubs.ts",
    "test:integration": "tsx src/integration-test.ts",
    "test:content": "tsx src/test-html-to-md.ts",
    "test:errors": "tsx src/test-error-handling.ts",
    "test:cms-pull": "tsx src/test-cms-pull.ts",
    "test:inject": "tsx src/test-inject-images.ts",
    "test:doc-index": "tsx src/test-doc-index.ts",
    "test:image-rewrite": "tsx src/test-image-rewrite.ts",
    "test:all": "tsx src/test-report.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "dotenv": "^16.4.7",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.1.0",
    "node-html-parser": "^7.1.0",
    "sanitize-html": "^2.14.0",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.13.10",
    "@types/sanitize-html": "^2.13.0",
    "@types/turndown": "^5.0.5",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=20"
  }
}
