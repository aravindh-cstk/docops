{
  "name": "@contentstack/docs-sync",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync": "tsx src/index.ts",
    "lint": "tsx src/lint.ts",
    "fix": "tsx src/fix.ts",
    "fix:check": "npm run fix && npm run lint",
    "cms-pull": "tsx src/cms-pull.ts",
    "test:integration": "tsx src/integration-test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "dotenv": "^16.4.7",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.1.0",
    "sanitize-html": "^2.14.0",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.13.10",
    "@types/sanitize-html": "^2.13.0",
    "@types/turndown": "^5.0.5",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=20"
  }
}
